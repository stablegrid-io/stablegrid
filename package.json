{
  "name": "stablegrid.io",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:cover": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:key": "playwright test tests/e2e/login.spec.ts tests/e2e/functions.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:perf:e2e": "PERF_ASSERT=1 npm run build && PERF_ASSERT=1 playwright test -c playwright.perf.config.ts tests/e2e/performance.spec.ts",
    "perf:lighthouse": "npx --yes @lhci/cli@0.14.x autorun --config=.lighthouserc.json"
  },
  "dependencies": {
    "@monaco-editor/react": "4.6.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "date-fns": "^4.1.0",
    "framer-motion": "11.2.0",
    "lucide-react": "0.378.0",
    "monaco-editor": "^0.55.1",
    "next": "14.2.3",
    "next-themes": "^0.4.6",
    "node-fetch": "3.3.2",
    "pyodide": "0.25.1",
    "react": "18.3.0",
    "react-confetti": "^6.4.0",
    "react-dom": "18.3.0",
    "react-resizable-panels": "2.0.19",
    "react-use": "^17.6.0",
    "recharts": "^3.7.0",
    "stripe": "^20.3.1",
    "tailwindcss": "3.4.1",
    "three": "^0.161.0",
    "typescript": "5.4.5",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.11.30",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.3",
    "jsdom": "^28.1.0",
    "postcss": "8.4.38",
    "prettier": "3.2.5",
    "vite": "^5.4.14",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.6.1"
  }
}
