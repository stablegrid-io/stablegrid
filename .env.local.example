NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site origin — used by Stripe checkout/portal return URLs.
# Leave blank in local dev (falls back to request origin); set for prod/staging
# (e.g. https://stablegrid.io).
NEXT_PUBLIC_URL=

# Stripe — create a Product "stableGrid Supporter" with a recurring €2.99/month
# price in the Stripe dashboard, then paste the price_... ID here.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUPPORTER_PRICE_ID=
# Legacy fallback for older deployments that used "Pro" naming. Safe to omit
# if STRIPE_SUPPORTER_PRICE_ID is set.
STRIPE_PRO_PRICE_ID=

STABLEGRID_E2E_EMAIL=
STABLEGRID_E2E_PASSWORD=
ALLOW_E2E_USER_CREATION=false
NEXT_PUBLIC_GRID_SCENE_DISABLE=false
